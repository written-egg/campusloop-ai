{
  "name": "ai-campus-secondhand-workbench",
  "version": "1.0.0",
  "private": true,
  "description": "AI second-hand ecommerce workbench for course demonstration with DeepSeek proxy and local fallback.",
  "scripts": {
    "start": "node server.js",
    "check:sql": "node tools/check-sql-connection.js",
    "check:auth-db": "node tools/check-auth-database.js",
    "check:auth-api": "node tools/check-auth-api.js",
    "check:advanced-db": "node tools/check-advanced-database.js",
    "check:search": "node tools/check-search-matching.js",
    "check:marketplace-api": "node tools/check-marketplace-api.js",
    "check:social-ai-api": "node tools/check-social-ai-api.js",
    "check:admin-api": "node tools/check-admin-api.js",
    "check:account-api": "node tools/check-account-api.js",
    "migrate:auth": "node tools/run-sql-file.js database/migrations/002_auth_and_advanced_objects.sql",
    "migrate:product-description": "node tools/run-sql-file.js database/migrations/003_product_description_view.sql",
    "migrate:admin": "node tools/run-sql-file.js database/migrations/004_admin_moderation.sql",
    "migrate:account": "node tools/run-sql-file.js database/migrations/005_account_management.sql"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "mssql": "^12.7.0"
  }
}
